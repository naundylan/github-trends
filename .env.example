# Dùng khi test local (npm run crawl). Trên GitHub Action thật sự dùng Secrets/Variables,
# KHÔNG commit file .env thật lên repo.

GH_TOKEN=ghp_xxx                     # PAT quyền repo (contents read/write)
OPENROUTER_API_KEY=sk-or-xxx
OPENROUTER_MODEL=poolside/laguna-xs.2:free
TELEGRAM_BOT_TOKEN=123456:ABC-xxx
TELEGRAM_CHAT_ID=123456789
TRENDING_LANGUAGES=                  # để trống = all + js,python,typescript,go,rust
GITHUB_REPOSITORY=your-username/github-trends
